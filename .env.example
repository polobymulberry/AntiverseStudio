# Global path
BODY_TEMPLATE_ROOT=/mnt/jfs_tikv/panjianxiong/drdoll/data/solid_full_body
OUTPUT_ROOT=output

# 流水线产品线子目录（位于 OUTPUT_ROOT 下）：默认「手办服装IP」；新作「卡通人偶定制」请改为 PIPELINE_LINE=卡通人偶定制
# PIPELINE_LINE=手办服装IP

# Qwen (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=beijing
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ENABLE_THINKING=true
QWEN_THINKING_BUDGET=4000

# Doubao Seedream
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_GENERATION_ENDPOINT=/api/v3/images/generations

# OSS
OBJECT_STORAGE_PROVIDER=aliyun
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_ENDPOINT_URL=https://oss-cn-beijing.aliyuncs.com
OSS_PUBLIC_URL=https://drdoll-public.oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=drdoll-public

# Tencent Hunyuan 3D
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
TENCENT_TEXTURE_MODEL=3.1
