# Global path
BODY_TEMPLATE_ROOT=/mnt/jfs_tikv/panjianxiong/drdoll/data/solid_full_body
OUTPUT_ROOT=output

# 流水线产品线子目录（位于 OUTPUT_ROOT 下）：默认「手办服装IP」；人偶线 PIPELINE_LINE=卡通人偶定制；宠物线 PIPELINE_LINE=宠物定制
# PIPELINE_LINE=手办服装IP

# 宠物定制（拉模 API；endpoint 契约随外部仓库演进）
# PET_CUSTOMIZATION_API_BASE_URL=https://pet-custom.example.com
# PET_CUSTOMIZATION_API_KEY=
# PET_CUSTOMIZATION_ORDER_PATH=api/v1/orders/{order_id}/model
# PET_CUSTOMIZATION_API_TIMEOUT=60
# PET_CUSTOMIZATION_DOWNLOAD_TIMEOUT=300
# PET_CUSTOMIZATION_MAX_RETRIES=3
# PET_RELIEF_BLEND_FILE=resource/blender/pet_relief_360.blend
# PET_MODEL_REFERENCE_ROOT=resource/pet_model_reference

# Qwen (DashScope Chat)
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=beijing
DASHSCOPE_MODEL=qwen3.6-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ENABLE_THINKING=true
QWEN_THINKING_BUDGET=4000

# Qwen-Image-2512 本地 diffusers（Pet Stage2；需 conda activate qwen-image 或等价 GPU 环境）
# QWEN_IMAGE_MODEL_PATH=/mnt/jfs_tikv/panjianxiong/gpustack_data/cache/model_scope/Qwen/Qwen-Image-2512
# QWEN_IMAGE_WIDTH=1024
# QWEN_IMAGE_HEIGHT=1024
# QWEN_IMAGE_TRUE_CFG_SCALE=4.0
# QWEN_IMAGE_NUM_INFERENCE_STEPS=28
# QWEN_IMAGE_BASE_SEED=1472666871
# QWEN_IMAGE_NEGATIVE_PROMPT=模糊，低质量，变形，水印，文字…
# NUM_GPUS_TO_USE=8
# GPUS_PER_INSTANCE=2

# Doubao Seedream
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_GENERATION_ENDPOINT=/api/v3/images/generations

# OSS
OBJECT_STORAGE_PROVIDER=aliyun
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_ENDPOINT_URL=https://oss-cn-beijing.aliyuncs.com
OSS_PUBLIC_URL=https://drdoll-public.oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=drdoll-public

# Tencent Hunyuan 3D
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
TENCENT_TEXTURE_MODEL=3.1
